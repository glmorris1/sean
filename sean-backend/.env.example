PORT=8787
PUBLIC_BASE_URL=http://192.168.1.126:8787
NODE_ENV=development
APP_SECRET=replace-with-a-long-random-production-secret
DATABASE_URL=
CORS_ORIGINS=
ALLOW_DEVELOPMENT_CODES=true
FIREBASE_PROJECT_ID=ghosttrade-app

# Required only if using the custom backend email/password auth path.
# Firebase Auth is preferred for production email verification.
# Example Gmail: host=smtp.gmail.com, port=465, secure=true, user=you@gmail.com, pass=app-password
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=GhostTrade <no-reply@ghosttrade.local>
